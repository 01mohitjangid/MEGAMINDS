# Copy this file to `.env` and fill in real values. NEVER commit the real .env.

# --- Application ---
APP_ENV=development
# Comma-separated list of origins allowed to call the API (the frontend URL).
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Database ---
# Any PostgreSQL works. You can paste a provider's URL verbatim — the app
# auto-adds the async "+psycopg" driver if it's missing.
#
# Option 1 (recommended) — Neon serverless Postgres (free, cloud-hosted).
# Copy the connection string from the Neon dashboard. Use the DIRECT connection
# (not the "-pooler" one) so Alembic migrations run cleanly. It looks like:
#   DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require
#
# Option 2 — Local Postgres via docker-compose (host port 5433 -> 5432):
#   DATABASE_URL=postgresql+psycopg://megaminds:megaminds@localhost:5433/megaminds
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require

# --- Auth (used from Phase 2 onward) ---
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- AI provider (used from Phase 3 onward) ---
GEMINI_API_KEY=
# gemini-flash-latest = current free-tier flash model. Avoid the pinned
# "gemini-2.0-flash" — its free-tier quota is now 0 (retired).
GEMINI_MODEL=gemini-flash-latest
